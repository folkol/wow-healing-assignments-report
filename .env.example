# Create a client at https://www.warcraftlogs.com/api/clients/
WCL_CLIENT_ID=
WCL_CLIENT_SECRET=

# Default guild (used by wcl_list_reports when no guild is passed).
WCL_GUILD_NAME=Ancient Circle
WCL_GUILD_REGION=EU
WCL_GUILD_REALM=tarren-mill

# IANA timezone used when resolving natural-language dates like "last Monday".
# Defaults to UTC if unset.
WCL_TIMEZONE=Europe/Stockholm
